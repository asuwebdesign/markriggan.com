{% extends "_layout" %}
{% set title = "Work" %}
{% set bodyClass = 'theme-dark' %}

{% block content %}
<article itemscope="" itemtype="http://schema.org/WebPage">
  <header class="band" data-padding="giant" data-align="center">
    <div class="title">
      <h1>{{ entry.featuredTitle }}</h1>
      <p>{{ entry.featuredSubtitle }}</p>
    </div>
  </header>

  <section class="band" data-padding="bottom-big" data-align="center">
    <div class="wrapper">
      <h2 class="ui-hidden">Featured Projects</h2>
      <div class="projects" data-size="3">
        {% for entry in craft.entries.section('projects').find() %}
          {% if entry.featuredImage | length %}
            {% set thumbnail = entry.featuredImage.first() %}
          {% endif %}
          <div class="project">
            <a class="project__link" href="{{ entry.url }}" style="background-image: url({{ thumbnail.url }});">
              <h3 class="project__title">{{ entry.title }}</h3>
            </a>
          </div>
        {% endfor %}
      </div>
    </div>
  </section>

  <section class="band" data-align="center">
    <div class="wrapper">
      <div class="title">
        <h2>{{ dribbble.featuredTitle }}</h2>
        <p>{{ dribbble.featuredSubtitle }}</p>
      </div>
      <div id="shots" class="shots" data-size="6"></div>
    </div>
  </section>
</article>
{% endblock %}

{% block scripts %}
<script src="{{ siteUrl }}js/dribbble.js"></script>
<script>
$.jribbble.setToken('21e6d63a0005cdec7cd62f3a450845523b7c59151bad82d32544f470037961be');
$.jribbble.users('markr').shots().then(function(res) {
  var html = [];
  res.forEach(function(shot) {
    html.push('<div class="shot">');
    html.push('<a href="' + shot.html_url + '" target="_blank">');
    html.push('<img src="' + shot.images.normal + '" draggable="false">');
    html.push('</a>');
    html.push('</div>')
  });
  $('#shots').html(html.join(''));
}).then(function() {
  var api = $('#barba-wrapper').data('jsp');
  api.reinitialise();
});
</script>
{% endblock %}
