{#
# Layout template
# ---------------
#
# This template defines your site’s global layout. It can be
# “extended” by other templates to fill in the gaps.
#
# See Twig’s Template Inheritance documentation for more details:
# http://twig.sensiolabs.org/doc/templates.html#template-inheritance
#}

<!DOCTYPE html>
<html lang="en-US">
<head>
	<script src="https://use.typekit.net/ysg6zwt.js"></script>
	<script>try{Typekit.load({ async: true });}catch(e){}</script>

	<meta charset="utf-8" />
	<meta http-equiv="cleartype" content="on">
	<meta http-equiv="X-UA-Compatible" content="IE=Edge,chrome=1">
	<meta name="viewport" content="width=device-width, minimum-scale=1, maximum-scale=1, user-scalable=no">

	{% hook 'seomaticRender' %}

	<link rel="stylesheet" href="{{ siteUrl }}/css/style.css" media="screen">
	<link rel="shortcut icon" href="{{ siteUrl }}/favicons/favicon.png">
</head>
<body>

	{# App Header #}
	<header id="app__header" class="app__header" role="banner">
		<h1 class="brand">
			<a href="{{ siteUrl }}" title="Home page for Mark Riggan" rel="home">
				<span>{{ siteName }}</span>
			</a>
		</h1>
		{% include 'components/_navigation' %}
	</header>


	{# App Content #}
	<main id="barba-wrapper" class="app__content" role="main">
    <div class="barba-container">

  		{% block content %}
				{# Placeholder for content per template #}
  		{% endblock %}

    </div>
	</main>


	{# App Menu #}
	<div id="app__menu" class="app__menu">
		<h2>Navigate</h2>
		<ul>
			{% nav node in craft.menus.getNodes('mainMenu') %}
				<li class="menu__item" role="presentation">
					<a href="{{node.link}}">{{ node.title }}</a>
				</li>
			{% endnav %}
		</ul>
	</div>


	{# App Footer #}
	<footer class="app__footer" role="contentinfo">
		{% include 'components/_cta' %}
		<div class="wrapper">
			{% include 'components/_tagline' %}
			{% include 'components/_social-links' %}
			{% include 'components/_copyright' %}
		</div>
	</footer>


	{# Global Scripts #}
	<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.1.1/jquery.min.js"></script>
	<script src="https://cdnjs.cloudflare.com/ajax/libs/enquire.js/2.1.2/enquire.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/barba.js/1.0.0/barba.js"></script>
	<script src="https://cdnjs.cloudflare.com/ajax/libs/headroom/0.9.3/headroom.min.js"></script>
  <script>
		// Init Barba.js
    Barba.Pjax.start();
    Barba.Prefetch.init();

		// Init HeadRoom.js
		var header = document.getElementById('app__header');
		var headroom = new Headroom(header, {
			offset: 75,
			classes: {
				initial:   'app__header--init',
				pinned:    'app__header--pinned',
				unpinned:  'app__header--unpinned',
				top:       'app__header--top',
				notTop:    'app__header--not-top',
				bottom:    'app__header--bottom',
				notBottom: 'app__header--not-bottom'
			}
		});

		headroom.init();
  </script>


	{% block scripts %}
		{# Placeholder for scripts per template #}
	{% endblock %}
</body>
</html>
