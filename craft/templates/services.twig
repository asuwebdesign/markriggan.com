{% extends "_layout" %}

{% block content %}

<article>
  {% include '_partials/_hero' %}

  {{ entry.body }}

  <section class="row">
    <div class="card service col-lg-6">
      <h2>Brand Communication</h2>
      <p>
        We make the complex simple through digital strategy and design. We create products, platforms and campaigns that move products as well as culture.
      </p>
      <ul>
        <li>Brand Strategy</li>
        <li>Design / Visual Language</li>
        <li>Advertising / Campaigns</li>
        <li>User Experience Design</li>
        <li>Social Campaigns</li>
        <li>eCommerce / Retail</li>
        <li>Content Development</li>
        <li>Digital Installations</li>
        <li>Web Apps / Products</li>
        <li>Mobile Design</li>
      </ul>
    </div>
    <div class="col-lg-6">
      <h2>Digital Innovation</h2>
