  <div id="process-discover">
    <div class="row start-xs">
      <div class="col-lg-4 col-lg-offset-6">
        <h3>Discover</h3>
        <p>Develop a thorough understanding of the project, audience, and objectives to formulate a digital strategy.</p>
      </div>
    </div>
  </div>
  <div style="">
    <div class="row start-xs">
      <div class="col-lg-4 col-lg-offset-6">
        <h3>Design</h3>
        <p>Develop a thorough understanding of the project, audience, and objectives to formulate a digital strategy.</p>
      </div>
    </div>
  </div>
  <div style="background-color: #eee;">
    <div class="row start-xs">
      <div class="col-lg-4 col-lg-offset-6">
        <h3>Develop</h3>
        <p>Develop a thorough understanding of the project, audience, and objectives to formulate a digital strategy.</p>
      </div>
    </div>
  </div>
  <div style="">
    <div class="row start-xs">
      <div class="col-lg-4 col-lg-offset-6">
        <h3>Deploy</h3>
        <p>Develop a thorough understanding of the project, audience, and objectives to formulate a digital strategy.</p>
      </div>
    </div>
  </div>
  <div style="background-color: #eee;">
    <div class="row start-xs">
      <div class="col-lg-4 col-lg-offset-6">
        <h3>Distill</h3>
        <p>Develop a thorough understanding of the project, audience, and objectives to formulate a digital strategy.</p>
      </div>
    </div>
  </div>
</section>

<div class="clients">
{% for block in general.clients %}
  <figure class="client">
    <img src="{{ block.clientLogo.first().url }}" alt="{{ block.clientName }}" draggable="false">
  </figure>
{% endfor %}
</div>

<div class="awards">
  {% for block in general.awards %}
  <figure class="award">
    <img src="{{ block.awardLogo.first().url }}" alt="{{ block.awardName }}" draggable="false">
  </figure>
  {% endfor %}
</div>

</article>

{% endblock %}

{% block scripts %}{% endblock %}
